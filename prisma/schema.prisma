generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Vehicle {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  category      String
  tagline       String
  image         String
  range         String
  topSpeed      String
  acceleration  String
  startingPrice Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  role              String             @default("USER")
  accounts          Account[]
  sessions          Session[]
  orders            Order[]
  demoDriveRequests DemoDriveRequest[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id            String   @id @default(cuid())
  userId        String?
  vehicleSlug   String
  vehicleName   String
  paintId       String
  wheelId       String
  interiorId    String
  basePrice     Int
  paintPrice    Int
  wheelPrice    Int
  interiorPrice Int
  totalPrice    Int
  paymentStatus String   @default("PENDING")
  paymentMethod String?
  paymentReference String?
  paidAt        DateTime?
  submittedAt   DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model DemoDriveRequest {
  id                String   @id @default(cuid())
  userId            String?
  referenceId       String   @unique
  vehicleSlug       String
  vehicleName       String
  fullName          String
  email             String
  phone             String
  location          String
  preferredDate     String
  preferredTimeSlot String
  submittedAt       DateTime
  createdAt         DateTime @default(now())
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}
